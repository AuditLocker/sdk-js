{
  "name": "@auditlocker/sdk",
  "version": "0.0.0",
  "author": "AuditLocker <support@auditlocker.co>",
  "bugs": {
    "url": "https://github.com/auditlocker/sdk-js/issues"
  },
  "description": "Official JavaScript / TypeScript client for the AuditLocker managed audit-logging service",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://auditlocker.co",
  "keywords": [
    "audit",
    "logging",
    "compliance",
    "soc2",
    "sdk",
    "auditlocker"
  ],
  "license": "Apache-2.0",
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "vite": "^8"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auditlocker/sdk-js.git"
  },
  "type": "module",
  "tshy": {
    "compiler": "tsgo",
    "sourceDialects": [
      "@auditlocker/sdk/source"
    ],
    "exports": {
      ".": "./src/custom/index.ts",
      "./package.json": "./package.json",
      "./types": "./src/types/index.ts",
      "./models/errors": "./src/models/errors/index.ts",
      "./models": "./src/models/index.ts",
      "./models/operations": "./src/models/operations/index.ts",
      "./*.js": "./src/*.ts",
      "./*": "./src/*.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "lint": "oxlint --max-warnings=0 --deny-warnings src/**/*.ts src/**/*.tsx",
    "build": "tshy",
    "prepublishOnly": "npm run build",
    "attw": "attw --pack . --profile node16",
    "audit:ci": "pnpm dlx audit-ci@7.1.0 --config ./audit-ci.jsonc",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "publint": "publint",
    "regen": "speakeasy run --skip-versioning && node scripts/repoint-entry.mjs && pnpm install && pnpm build",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.60.0",
    "publint": "^0.3",
    "rolldown": "1.0.0-rc.18",
    "tshy": "^3.3.2",
    "typescript": "~5.8.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "zod": "^3.25.65 || ^4.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "@auditlocker/sdk/source": "./src/custom/index.ts",
        "types": "./dist/esm/custom/index.d.ts",
        "default": "./dist/esm/custom/index.js"
      },
      "require": {
        "types": "./dist/commonjs/custom/index.d.ts",
        "default": "./dist/commonjs/custom/index.js"
      }
    },
    "./package.json": "./package.json",
    "./types": {
      "import": {
        "@auditlocker/sdk/source": "./src/types/index.ts",
        "types": "./dist/esm/types/index.d.ts",
        "default": "./dist/esm/types/index.js"
      },
      "require": {
        "types": "./dist/commonjs/types/index.d.ts",
        "default": "./dist/commonjs/types/index.js"
      }
    },
    "./models/errors": {
      "import": {
        "@auditlocker/sdk/source": "./src/models/errors/index.ts",
        "types": "./dist/esm/models/errors/index.d.ts",
        "default": "./dist/esm/models/errors/index.js"
      },
      "require": {
        "types": "./dist/commonjs/models/errors/index.d.ts",
        "default": "./dist/commonjs/models/errors/index.js"
      }
    },
    "./models": {
      "import": {
        "@auditlocker/sdk/source": "./src/models/index.ts",
        "types": "./dist/esm/models/index.d.ts",
        "default": "./dist/esm/models/index.js"
      },
      "require": {
        "types": "./dist/commonjs/models/index.d.ts",
        "default": "./dist/commonjs/models/index.js"
      }
    },
    "./models/operations": {
      "import": {
        "@auditlocker/sdk/source": "./src/models/operations/index.ts",
        "types": "./dist/esm/models/operations/index.d.ts",
        "default": "./dist/esm/models/operations/index.js"
      },
      "require": {
        "types": "./dist/commonjs/models/operations/index.d.ts",
        "default": "./dist/commonjs/models/operations/index.js"
      }
    },
    "./*.js": {
      "import": {
        "@auditlocker/sdk/source": "./src/*.ts",
        "types": "./dist/esm/*.d.ts",
        "default": "./dist/esm/*.js"
      },
      "require": {
        "types": "./dist/commonjs/*.d.ts",
        "default": "./dist/commonjs/*.js"
      }
    },
    "./*": {
      "import": {
        "@auditlocker/sdk/source": "./src/*.ts",
        "types": "./dist/esm/*.d.ts",
        "default": "./dist/esm/*.js"
      },
      "require": {
        "types": "./dist/commonjs/*.d.ts",
        "default": "./dist/commonjs/*.js"
      }
    }
  },
  "main": "./dist/commonjs/custom/index.js",
  "types": "./dist/commonjs/custom/index.d.ts",
  "module": "./dist/esm/custom/index.js"
}
